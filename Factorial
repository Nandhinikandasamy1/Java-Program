import java.util.Scanner;

public class Factorial {

	private static Scanner sc;

	public static void main(String[] args) {
		
		int b = 1,i;
		
		sc = new Scanner(System.in);
		
		System.out.println("Type number to find Factorial: ");
		
		int a = sc.nextInt();
		
		for (i=1;i<=a;i++) {
			
			b=b*i;
		}
				
		System.out.println(b);
	}

}
